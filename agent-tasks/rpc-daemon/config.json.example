{
  "name": "RPC Daemon (example-project)",
  "uniqueKey": "example-project:rpc-daemon",
  "groupName": "example-project",
  "description": "Polls MongoDB for remote function calls and executes locally (residential IP)",
  "script": {
    "path": "daemon",
    "args": ["--verbose"],
    "interpreter": "npm",
    "workingDirectory": "/path/to/example-project"
  },
  "schedule": {
    "type": "daemon"
  },
  "daemon": {
    "restartDelayMs": 5000,
    "maxRestarts": 5,
    "restartWindowMs": 300000,
    "healthyRunMs": 60000
  },
  "notifications": {
    "onStart": false,
    "onSuccess": false,
    "onFailure": true
  },
  "options": {
    "enabled": true,
    "allowParallelRuns": false,
    "requiresInternet": true
  },
  "output": {
    "logFile": "/path/to/example-project/agent-tasks/rpc-daemon/runs/output.log",
    "statusFile": "/path/to/example-project/agent-tasks/rpc-daemon/runs/status.json"
  }
}
