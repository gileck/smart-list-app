{
  "name": "Agent(example-project): All",
  "uniqueKey": "example-project:agent:all",
  "groupName": "example-project",
  "description": "Runs all workflow agents sequentially every 10 minutes",
  "script": {
    "path": "github-workflows-agent",
    "args": ["--all", "--global-limit", "--stream", "--reset", "--stale-timeout", "20", "--triggeredBy", "task-manager"],
    "interpreter": "npm",
    "workingDirectory": "/path/to/agents-copy/example-project"
  },
  "schedule": {
    "type": "interval",
    "value": "600000"
  },
  "retry": {
    "enabled": true,
    "maxAttempts": 3,
    "backoffType": "exponential",
    "initialDelayMs": 10000,
    "maxDelayMs": 60000
  },
  "timeout": { "ms": 900000 },
  "notifications": {
    "onStart": false,
    "onSuccess": false,
    "onFailure": true
  },
  "options": {
    "enabled": true,
    "allowParallelRuns": false,
    "requiresInternet": true
  },
  "output": {
    "logFile": "/path/to/example-project/agent-tasks/all/runs/output.log",
    "statusFile": "/path/to/example-project/agent-tasks/all/runs/status.json"
  }
}
