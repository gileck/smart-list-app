{
  "name": "@__NAME__/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing the @__NAME__/sdk as tools.",
  "main": "dist/server.js",
  "bin": {
    "__NAME__-mcp": "dist/server.js"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bundle": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/server.bundle.mjs",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@__NAME__/sdk": "file:../__NAME__-sdk"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
